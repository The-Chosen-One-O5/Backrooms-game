{
  "buildCommand": "echo done",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
